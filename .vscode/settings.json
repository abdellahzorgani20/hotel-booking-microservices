{
  "python.defaultInterpreterPath": "${workspaceFolder}/auth-service/.venv/Scripts/python.exe",
  "editor.formatOnSave": true,
  "python.formatting.provider": "autopep8",
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.venv": false
  },
  "postman.settings.dotenv-detection-notification-visibility": false
}